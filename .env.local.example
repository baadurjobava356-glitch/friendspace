# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: TURN server for WebRTC NAT traversal (metered.ca free tier)
NEXT_PUBLIC_TURN_ENABLED=false
METERED_API_KEY=your_metered_api_key
METERED_APP_NAME=openrelay

# Optional: Vercel Blob for file uploads
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token

# Optional: Resend for auth and reset emails
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=FriendSpace <no-reply@yourdomain.com>

# Mini Discord MVP caps
MINI_DISCORD_STORAGE_BUCKET=discord-files
MINI_DISCORD_MAX_FILE_BYTES=10485760
MINI_DISCORD_MAX_STORAGE_PER_GROUP_BYTES=262144000
MINI_DISCORD_MAX_VOICE_PARTICIPANTS=12

# Optional: LiveKit for production voice/screen media server
NEXT_PUBLIC_LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
