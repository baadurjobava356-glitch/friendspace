# ─── Supabase ────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Get these from: Supabase Dashboard → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_publishable_key_here
SUPABASE_SECRET_KEY=your_supabase_secret_key_here

# ─── Vercel Blob (file uploads) ───────────────────────────────────────────────
# Required for the file upload system to work.
# How to get it:
#   1. Go to vercel.com/dashboard → Storage tab
#   2. Create a new Blob store (free tier available)
#   3. Copy the Read/Write token and paste it below
#
# Without this token the /api/upload route will return a 503 error.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_YOUR_TOKEN_HERE
