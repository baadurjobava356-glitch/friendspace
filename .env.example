# ─── Supabase ────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Get these from: Supabase Dashboard → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_publishable_key_here
SUPABASE_SECRET_KEY=your_supabase_secret_key_here

# ─── Vercel Blob (file uploads) ───────────────────────────────────────────────
# Required for the file upload system to work.
# How to get it:
#   1. Go to vercel.com/dashboard → Storage tab
#   2. Create a new Blob store (free tier available)
#   3. Copy the Read/Write token and paste it below
#
# Without this token the /api/upload route will return a 503 error.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_YOUR_TOKEN_HERE

# ─── Resend (auth verification and password reset emails) ─────────────────────
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL=FriendSpace <no-reply@yourdomain.com>

# ─── Mini Discord MVP limits ──────────────────────────────────────────────────
MINI_DISCORD_STORAGE_BUCKET=discord-files
MINI_DISCORD_MAX_FILE_BYTES=10485760
MINI_DISCORD_MAX_STORAGE_PER_GROUP_BYTES=262144000
MINI_DISCORD_MAX_VOICE_PARTICIPANTS=12

# ─── LiveKit (voice + screen share transport) ────────────────────────────────
NEXT_PUBLIC_LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
